{
  "name": "ismyaialive",
  "version": "1.0.0",
  "description": "Help people get a second perspective on their AI conversations",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test tests/*.test.js",
    "smoke": "node tests/smoke.mjs",
    "smoke:local": "ISMYAIALIVE_URL=http://localhost:8788 node tests/smoke.mjs",
    "test:security": "node --test tests/security.test.js",
    "test:analyzer": "node --test tests/analyzer.test.js",
    "test:integration": "node tests/integration.test.js",
    "test:ui": "npx playwright test tests/ui-features.spec.js",
    "test:e2e": "npx playwright test tests/e2e-allan-brooks.spec.js",
    "test:journey": "node tests/run-allan-journey.js",
    "test:all": "npm run test && npm run test:integration && npm run test:ui",
    "lint": "echo 'No linting configured'"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "mental-health",
    "chatgpt",
    "analysis",
    "sycophancy"
  ],
  "author": "Is My AI Alive? Contributors",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.58.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "wrangler": "^4.86.0"
  }
}
